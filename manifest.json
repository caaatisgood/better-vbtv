{
  "manifest_version": 3,
  "name": "Better VBTV",
  "version": "1.1.1",
  "description": "Watch VBTV (Volleyball World TV) replays spoiler-free, with keyboard seek, playback speed, shortcuts overlay, and resume history.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "src/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://tv.volleyballworld.com/*"],
      "js": ["src/content.ts"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
